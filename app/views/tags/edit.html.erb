<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.editing", model: t("activerecord.models.tag")) %></h5>
    <div id="content_list" class="card-body">

      <%= form_for(@tag, url: tag_path(@tag.name)) do |f| %>
        <%= error_messages(@tag) %>
        <div class="field">
          <%= f.label :name %><br/>
          <%= f.text_field :name, value: @tag.name, class: "form-control" %>
        </div>

        <div class="actions mt-3">
          <%= f.submit class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.show"), tag_path(@tag.name) %></li>
      <li><%= link_to t("page.back"), tags_path %></li>
    </ul>
  </div>
</div>
