<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.showing", model: t("activerecord.models.periodical")) -%></h5>
    <div id="content_list" class="card-body">
      <p id="notice"><%= notice %></p>

      <p>
        <strong><%= t("activerecord.attributes.periodical.original_title") -%>:</strong>
        <%= @periodical.original_title -%>
      </p>

      <p>
        <strong><%= t("activerecord.models.manifestation") -%>:</strong>
        <%= link_to @periodical.manifestation.original_title, @periodical.manifestation -%>
      </p>

      <p>
        <strong><%= t("activerecord.models.frequency") -%>:</strong>
        <%= link_to @periodical.frequency.display_name.localize, @periodical.frequency -%>
      </p>

      <p>
        <strong><%= t("page.created_at") -%>:</strong>
        <%= l(@periodical.created_at) -%>
      </p>

      <p>
        <strong><%= t("page.updated_at") -%>:</strong>
        <%= l(@periodical.updated_at) -%>
      </p>
    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.listing", model: t("activerecord.models.periodical")),
        periodicals_path -%></li>
    </ul>
  </div>
</div>
