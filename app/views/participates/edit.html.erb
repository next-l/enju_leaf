    <div id="content_list" class="card-body">
      <%= render "form", participate: @participate %>
    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.show"), @participate %></li>
      <li><%= link_to t("page.back"), participates_path %></li>
    </ul>
  </div>
</div>
