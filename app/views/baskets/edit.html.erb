<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.editing", model: t("activerecord.models.basket")) %></h5>
    <div id="content_list" class="card-body">

      <%= form_for(@basket) do |f| %>
        <%= error_messages(@basket) %>
        <div class="field">
          <%= f.label t("activerecord.models.user") %><br/>
          <%= @basket.user.username %>
          <%= f.hidden_field :user_id %>
        </div>

        <div class="field">
          <%= f.label :note %><br/>
          <%= f.text_area :note, class: "form-control resource_textarea" %>
        </div>

        <div class="actions mt-3">
          <%= f.submit class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.show"), basket_path(@basket) %></li>
      <li><%= link_to t("page.back"), baskets_path(user_id: @basket.user.username) %></li>
    </ul>
  </div>
</div>
