<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.editing", model: t("activerecord.models.agent_merge")) %></h5>
    <div id="content_list" class="card-body">

      <%= form_with(model: @agent_merge) do |f| %>
        <%= error_messages(@agent_merge) %>

        <div class="field">
          <%= f.label t("activerecord.models.agent") %><br/>
          <%= f.text_field :agent_id %>
        </div>

        <div class="field">
          <%= f.label t("activerecord.models.agent_merge_list") %><br/>
          <%= f.text_field :agent_merge_list_id %>
        </div>

        <div class="actions mt-3">
          <%= f.submit class: "btn btn-primary" %>
        </div>
      <% end %>

    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.show"), @agent_merge %></li>
      <li><%= link_to t("page.back"), agent_merges_path %></li>
    </ul>
  </div>
</div>
