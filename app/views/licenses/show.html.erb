<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.showing", model: t("activerecord.models.license")) -%></h5>
    <div id="content_list" class="card-body">
      <p id="notice"><%= notice %></p>

      <p>
        <strong><%= t("activerecord.attributes.license.name") -%>:</strong>
        <%= @license.name -%>
      </p>

      <p>
        <strong><%= t("activerecord.attributes.license.display_name") -%>:</strong>
        <%= @license.display_name.localize -%>
      </p>

      <p>
        <strong><%= t("activerecord.attributes.license.note") -%>:</strong>
        <%= @license.note -%>
      </p>
    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.edit"), edit_license_path(@license) -%></li>
      <li><%= back_to_index(flash[:page_info]) -%></li>
    </ul>
  </div>
</div>
