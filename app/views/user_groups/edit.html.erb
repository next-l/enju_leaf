<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.editing", model: t("activerecord.models.user_group")) -%></h5>
    <div id="content_list" class="card-body">
      <%= render "form", user_group: @user_group %>
    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.show"), user_group_path(@user_group) -%></li>
      <li><%= link_to t("page.back"), user_groups_path -%></li>
    </ul>
  </div>
</div>
