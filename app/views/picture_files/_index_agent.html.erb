<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.listing", model: t("activerecord.models.picture_file")) -%></h5>
    <div id="content_list" class="card-body">
      <p id="notice"><%= notice %></p>

      <h2 class="resource_title">
        [P]
        <%= link_to agent.full_name, agent -%>
      </h2>

      <table class="table table-striped index">
        <tr>
          <th id="position"></th>
          <th><%= t("page.attachable") -%></th>
          <th><%= t("activerecord.attributes.picture_file.picture_file_size") -%></th>
          <th><%= t("activerecord.attributes.picture_file.picture_content_type") -%></th>
          <th><%= t("activerecord.attributes.picture_file.picture_file_name") -%></th>
          <th></th>
        </tr>
        <%- @picture_files.each do |picture_file| -%>
          <tr class="line<%= cycle("0", "1") -%>">
            <td>
              <%- if policy(picture_file).update? -%>
                <%= move_position(picture_file) -%>
              <%- end -%>
            </td>
            <td>
              <%= if picture_file.picture_attachable
                link_to "#{h(picture_file.picture_attachable_type)}/#{h(picture_file.picture_attachable_id)}",
                picture_file.picture_attachable
              end -%>
            </td>
            <td><%= picture_file.attachment.byte_size -%></td>
            <td><%= picture_file.attachment.content_type -%></td>
            <td><%= if picture_file.attachment.attached?
                link_to picture_file.attachment.filename,
                rails_blob_path(picture_file.attachment)
              end -%></td>
            <td>
              <%= link_to t("page.show"), picture_file -%>
              <%- if policy(picture_file).update? -%>
                <%= link_to t("page.edit"), edit_picture_file_path(picture_file) -%>
              <% end %>
              <%- if policy(picture_file).destroy? -%>
                <%= link_to t("page.destroy"),
                picture_file_path(picture_file, agent_id: agent.id),
                data: {
                  confirm: t("page.are_you_sure"),
                },
                method: :delete -%>
              <%- end -%>
            </td>
          </tr>
        <%- end -%>
      </table>

      <%= paginate(@picture_files) -%>
    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <%- if policy(PictureFile).create? -%>
      <ul>
        <li><%= link_to t("page.new", model: t("activerecord.models.picture_file")),
          new_picture_file_path(agent_id: agent.id) -%></li>
        <li><%= link_to t("picture_file.all_picture"), picture_files_path -%></li>
      </ul>
    <%- end -%>
  </div>
</div>
