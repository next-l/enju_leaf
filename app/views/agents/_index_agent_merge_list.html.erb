<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.listing", model: t("activerecord.models.agent")) -%></h5>
    <div id="content_list" class="card-body">

      <div class="search_form">
        <%= form_for :agents, url: agent_merge_list_agents_path(@agent_merge_list), html: {method: 'get'} do -%>
          <p>
            <%= label_tag :search_form_top, t("page.search_term") -%>:
            <%= search_field_tag "query",
            h(@query),
            {
              id: "search_form_top",
              class: "search_form",
              placeholder: t("page.search_term"),
            } -%>
            <%- if policy(@agent_merge_list).update? -%>
              <%= render "page/add" %>
            <%- end -%>
            <%= submit_tag t("page.search") -%>
            <%= link_to t("page.back_to_index"), agent_merge_list_agents_path(@agent_merge_list) -%>
          </p>
        <%- end -%>
      </div>

      <table class="table table-striped index">
        <tr>
          <th><%= t("activerecord.attributes.agent.full_name") -%></th>
          <th><%= t("activerecord.models.agent_type") -%></th>
          <th><%= t("activerecord.attributes.agent.date_of_birth") -%></th>
          <th></th>
        </tr>

        <%- @agents.each do |agent| -%>
          <tr class="line<%= cycle("0", "1") -%>">
            <td><%= link_to agent.full_name, agent_merge_list_agent_path(@agent_merge_list, agent) -%></td>
            <td><%= agent.agent_type.display_name.localize -%></td>
            <td><%= l agent.date_of_birth if agent.date_of_birth -%></td>
            <td>
              <%- if policy(agent).destroy? -%>
                <%- if params[:mode] == 'add' -%>
                  <%= unless @agent_merge_list.agents.include?(agent)
                    link_to t("page.add"),
                    new_agent_merge_list_agent_merge_path(@agent_merge_list, agent_id: agent.id)
                  end -%>
                <%- else -%>
                  <%- agent_merge = @agent_merge_list.agent_merges.where(agent_id: agent.id).first -%>
                  <%= if agent_merge
                    link_to t("page.destroy"),
                    agent_merge_list_agent_merge_path(@agent_merge_list, agent_merge),
                    data: {
                      confirm: t("page.are_you_sure"),
                    },
                    method: :delete
                  end -%>
                <%- end -%>
              <%- end -%>
            </td>
          </tr>
        <%- end -%>
      </table>

      <%= paginate(@agents) -%>
    </div>
  </div>
</div>

<div id="submenu" class="col">
  <ul>
    <li><%= link_to t("page.listing", model: t("activerecord.models.agent_merge_list")),
      @agent_merge_list -%></li>
  </ul>
</div>
