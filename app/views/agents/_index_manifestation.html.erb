<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.listing", model: t("agent.publisher")) -%></h5>
    <div id="content_list" class="card-body">
      <p id="notice"><%= notice %></p>

      <%= render "manifestations/title", manifestation: manifestation -%>

      <div class="search_form">
        <%= form_for :agents, url: agents_path(manifestation_id: manifestation.id), html: {method: 'get'} do -%>
          <p>
            <%= label_tag :search_form_top, t("page.search_term") -%>:
            <%= search_field_tag "query",
            h(@query),
            {
              id: "search_form_top",
              class: "search_form",
              placeholder: t("page.search_term"),
            } -%>
            <%- if policy(manifestation).update? -%>
              <%= render "page/add" %>
            <%- end -%>
            <%= submit_tag t("page.search") -%>
            <%= link_to t("page.back_to_index"), agents_path(manifestation_id: manifestation.id) -%>
          </p>
        <%- end -%>
      </div>

      <table class="table table-striped index">
        <tr>
          <th><%= t("activerecord.attributes.agent.full_name") -%></th>
          <th><%= t("activerecord.models.produce_type") -%></th>
          <th><%= t("activerecord.models.agent_type") -%></th>
          <th></th>
        </tr>
        <%- @agents.each do |agent| -%>
          <tr class="line<%= cycle("0", "1") -%>">
            <td><%= link_to agent.full_name, agent -%></td>
            <td><%= if params[:mode] != "add" and manifestation.produced(agent).try(:produce_type)
                manifestation.produced(agent).produce_type.display_name.localize
              end -%></td>
            <td><%= agent.agent_type.display_name.localize -%></td>
            <td>
              <%- if policy(agent).destroy? -%>
                <%- if params[:mode] == 'add' -%>
                  <%= unless manifestation.publishers.include?(agent)
                    link_to t("page.add"),
                    new_produce_path(manifestation_id: manifestation.id, agent_id: agent.id)
                  end -%>
                <%- else -%>
                  <%= link_to t("page.edit"), edit_produce_path(manifestation.produced(agent)) -%>
                  <%= link_to t("page.destroy"),
                  produce_path(manifestation.produced(agent), manifestation_id: manifestation.id),
                  data: {
                    confirm: t("page.are_you_sure"),
                  },
                  method: :delete -%>
                <%- end -%>
              <%- end -%>
            </td>
          </tr>
        <%- end -%>
      </table>

      <%= paginate(@agents) -%>
    </div>
  </div>
</div>

<div id="submenu" class="col">
  <%= render "manifestations/book_jacket", manifestation: manifestation -%>
  <ul>
    <li><%= link_to t("activerecord.models.manifestation"), manifestations_path -%></li>
    <li><%= link_to t("page.listing", model: t("activerecord.models.item")),
      items_path(manifestation_id: manifestation.id) -%></li>
    <%- if policy(Agent).create? -%>
      <li><%= link_to t("page.new", model: t("activerecord.models.agent")),
        new_agent_path(manifestation_id: manifestation.id) -%></li>
      <li><%= link_to t("page.rearrange_order"),
        produces_path(manifestation_id: manifestation.id) %></li>
    <%- end -%>
  </ul>
</div>
