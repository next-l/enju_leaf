<%= form_with(model: language) do |f| %>
  <%= error_messages(language) %>

  <div class="field">
    <%= f.label :name %>:<br/>
    <%= language.name %>
  </div>

  <div class="field">
    <%= f.label :native_name %><br/>
    <%= f.text_field :native_name, class: "form-control" %>
  </div>

  <div class="field">
    <%= f.label :display_name %><br/>
    <%= f.text_area :display_name, class: "form-control" %>
  </div>

  <div class="field">
    <%= f.label :iso_639_1 %><br/>
    <%= f.text_field :iso_639_1, class: "form-control" %>
  </div>

  <div class="field">
    <%= f.label :iso_639_2 %><br/>
    <%= f.text_field :iso_639_2, class: "form-control" %>
  </div>

  <div class="field">
    <%= f.label :iso_639_3 %><br/>
    <%= f.text_field :iso_639_3, class: "form-control" %>
  </div>

  <div class="field">
    <%= f.label :note %><br/>
    <%= f.text_area :note, class: "form-control" %>
  </div>

  <div class="actions mt-3">
    <%= f.submit class: "btn btn-primary" %>
  </div>
<% end %>
