<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.editing", model: t("activerecord.models.news_post")) -%></h5>
    <div id="content_list" class="card-body">
      <%= render "form", news_post: @news_post %>
    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.show"), @news_post -%></li>
      <li><%= link_to t("page.back"), news_posts_path -%></li>
    </ul>
  </div>
</div>
