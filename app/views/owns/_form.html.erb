<%= form_with(model: own) do |f| %>
  <%= error_messages(own) %>

  <div class="field">
    <%= f.label t("activerecord.models.library") %><br/>
    <%= f.text_field :agent_id, class: "form-control" %>
  </div>

  <div class="field">
    <%= f.label t("activerecord.models.item") %><br/>
    <%= f.text_field :item_id, class: "form-control" %>
  </div>

  <div class="actions mt-3">
    <%= f.submit class: "btn btn-primary" %>
  </div>
<% end %>
