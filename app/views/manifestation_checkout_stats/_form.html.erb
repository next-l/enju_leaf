<%= form_with(model: manifestation_checkout_stat) do |f| %>
  <%= error_messages(manifestation_checkout_stat) %>

  <div class="field">
    <%= f.label :start_date %><br/>
    <%= f.datetime_select :start_date %>
  </div>
  <div class="field">
    <%= f.label :end_date %><br/>
    <%= f.datetime_select :end_date %>
  </div>
  <div class="field">
    <%= f.label :note %><br/>
    <%= f.text_area :note, class: "form-control" %>
  </div>
  <div class="actions mt-3">
    <%= f.hidden_field :mode, value: "import" %>
    <%= f.submit t("page.start_counting"), class: "btn btn-primary" %>
  </div>
<% end %>
