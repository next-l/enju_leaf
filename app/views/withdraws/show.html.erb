<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.showing", model: t("activerecord.models.withdraw")) -%></h5>
    <div id="content_list" class="card-body">
      <p id="notice"><%= notice %></p>

      <p>
        <strong><%= t("activerecord.models.item") -%>:</strong>
        <% if @withdraw.item %>
          <%= link_to @withdraw.item.item_identifier, @withdraw.item -%>
          (<%= link_to @withdraw.item.manifestation.original_title,
          @withdraw.item.manifestation %>)
        <% end %>
      </p>

      <p>
        <strong><%= t("activerecord.models.user") -%>:</strong>
        <%= if @withdraw.librarian.try(:profile)
          link_to @withdraw.librarian.username, @withdraw.librarian.profile
        end -%>
      </p>

      <p>
        <strong><%= t("page.created_at") -%>:</strong>
        <%= l @withdraw.created_at %>
      </p>

    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.back"), :back -%></li>
    </ul>
  </div>
</div>
