<%= form_with(model: agent_merge_list) do |f| %>
  <%= error_messages(agent_merge_list) %>
  <div class="field">
    <%= f.label :title %><br/>
    <%= f.text_field :title, required: true, class: "form-control" %>
  </div>

  <div class="actions mt-3">
    <%= f.submit class: "btn btn-primary" %>
  </div>
<% end %>
