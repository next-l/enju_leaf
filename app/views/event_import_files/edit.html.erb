<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.editing", model: t("activerecord.models.event_import_file")) %></h5>
    <div id="content_list" class="card-body">
      <%= form_with(model: @event_import_file) do |f| %>
        <%= error_messages(@event_import_file) %>

        <div class="field">
          <%= f.label :event_import_file_name %><br/>
          <%= f.text_field :event_import_file_name, class: "form-control" %>
        </div>

        <div class="field">
          <%= f.label :note %><br/>
          <%= f.text_area :note, class: "form-control" %>
        </div>

        <div class="actions mt-3">
          <%= f.submit class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.show"), @event_import_file %></li>
      <li><%= link_to t("page.back"), event_import_files_path %></li>
    </ul>
  </div>
</div>
