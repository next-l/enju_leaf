<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.new", model: t("activerecord.models.order_list")) %></h5>
    <div id="content_list" class="card-body">

      <%= form_with(model: @order_list) do |f| %>
        <%= error_messages(@order_list) %>

        <div class="field">
          <%= f.label :title %><br/>
          <%= f.text_field :title, class: "form-control resource_title" %>
        </div>
        <div class="field">
          <%= f.label t("activerecord.models.bookstore") %><br/>
          <%= f.select(:bookstore_id, @bookstores.collect { |b| [b.name, b.id] }, {}, class: "form-select") %>
        </div>
        <div class="field">
          <%= f.label :note %><br/>
          <%= f.text_area :note, class: "form-control resource_textarea" %>
        </div>
        <div class="actions mt-3">
          <%= f.submit class: "btn btn-primary" %>
        </div>
      <% end %>

    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.back"), order_lists_path %></li>
    </ul>
  </div>
</div>
