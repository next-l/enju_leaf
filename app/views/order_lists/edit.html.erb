<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.editing", model: t("activerecord.models.order_list")) %></h5>
    <div id="content_list" class="card-body">

      <%= form_with(model: @order_list) do |f| %>
        <%= error_messages(@order_list) %>

        <div class="field">
          <%= f.label :title %><br/>
          <% if @order_list.edit_mode == 'order' %>
            <%= @order_list.title %>
          <% else %>
            <%= f.text_field :title, required: true, class: "form-control resource_title" %>
          <% end %>
        </div>
        <div class="field">
          <%= f.label t("activerecord.models.bookstore") %><br/>
          <% if @order_list.edit_mode == 'order' %>
            <%= @order_list.bookstore.name %>
          <% else %>
            <%= f.select(
              :bookstore_id,
              @bookstores.collect { |b| [b.name, b.id] },
              { include_blank: true },
              class: "form-select"
            ) %>
          <% end %>
        </div>
        <% unless @order_list.edit_mode == 'order' %>
          <div class="field">
            <%= f.label :ordered_at %><br/>
            <%= f.text_field :ordered_at,
                         value: @order_list.ordered_at.try(:strftime, "%Y%m%d"),
                         class: "form-control date_field" %>
          </div>
        <% end %>
        <div class="field">
          <%= f.label :note %><br/>
          <%= f.text_area :note, class: "form-control resource_textarea" %>
        </div>
        <div class="actions mt-3">
          <%= f.hidden_field :edit_mode %>
          <% if @order_list.edit_mode == 'order' %>
            <%= f.submit t("order_list.create_order_sheet"), class: "btn btn-primary" %>
          <% else %>
            <%= f.submit class: "btn btn-primary" %>
          <% end %>
        </div>
      <% end %>

    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.show"), @order_list %></li>
      <li><%= link_to t("page.back"), order_lists_path %></li>
    </ul>
  </div>
</div>
