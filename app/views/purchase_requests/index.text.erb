title author publisher created_at order_list_title ordered_at bookstore
<%- @purchase_requests.each do |purchase_request| -%>
  "<%= h purchase_request.title.gsub(/"/, '""') -%>" "<%= h purchase_request.author -%>" "<%= h purchase_request.publisher -%>" "<%= h purchase_request.created_at -%>" "<%= begin
    h purchase_request.order_list.title
  rescue StandardError
    nil
  end -%>" "<%= begin
    h purchase_request.order_list.ordered_at
  rescue StandardError
    nil
  end -%>" "<%= begin
    h purchase_request.order_list.bookstore.name
  rescue StandardError
    nil
  end %>"<%= "\n" -%>
<%- end -%>
