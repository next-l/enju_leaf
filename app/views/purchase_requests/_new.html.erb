<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.new", model: t("activerecord.models.purchase_request")) -%></h5>
    <div id="content_list" class="card-body">

      <%= form_for(@purchase_request) do |f| -%>
        <%= error_messages(@purchase_request) -%>

        <div class="field">
          <%= f.label t("activerecord.models.user") -%><br/>
          <%- if @user -%>
            <%= link_to @user.username, @user.profile if @user.profile -%>
          <%- else -%>
            <%= link_to current_user.username, current_user.profile if current_user.profile -%>
          <%- end -%>
        </div>

        <div class="field">
          <%= f.label :title -%><br/>
          <%= f.text_area :title, required: true, class: "form-control resource_textarea" -%>
        </div>

        <div class="field">
          <%= f.label :author -%><br/>
          <%= f.text_area :author, class: "form-control resource_textarea" -%>
        </div>

        <div class="field">
          <%= f.label :publisher -%><br/>
          <%= f.text_area :publisher, class: "form-control resource_textarea" -%>
        </div>

        <div class="field">
          <%= f.label :isbn -%><br/>
          <%= f.text_field :isbn, class: "form-control resource_isbn_issn" -%>
        </div>

        <div class="field">
          <%= f.label :pub_date -%><br/>
          <%= f.text_field :pub_date, class: "form-control" -%>
        </div>

        <div class="field">
          <%= f.label :price -%><br/>
          <%= f.text_field :price, class: "form-control resource_integer" -%>
        </div>

        <div class="field">
          <%= f.label :url -%><br/>
          <%= f.url_field :url, class: "form-control resource_url" -%>
        </div>

        <div class="field">
          <%= f.label :note -%><br/>
          <%= f.text_area :note, class: "form-control resource_textarea" -%>
        </div>

        <div class="actions mt-3">
          <%= f.submit class: "btn btn-primary" %>
        </div>
      <%- end -%>

    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <%- if @user -%>
        <% if params[:url].try(:bookmarkable?) %>
          <li><%= link_to t("page.back"), :back %></li>
        <% end %>
        <li><%= link_to t("page.listing", model: t("activerecord.models.purchase_request")),
          purchase_requests_path(user_id: @user.username) -%></li>
      <%- else -%>
        <li><%= link_to t("page.listing", model: t("activerecord.models.purchase_request")),
          purchase_requests_path -%></li>
      <%- end -%>
    </ul>
  </div>
</div>
