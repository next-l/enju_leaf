<!DOCTYPE html>
<html
  xmlns="http://www.w3.org/1999/xhtml"
  xml:lang="<%= @locale.to_s -%>"
  lang="<%= @locale.to_s -%>"
>
  <head>
    <meta charset="UTF-8"/>
    <title><%= title(controller.controller_name) %></title>
    <%- if controller.action_name == 'index' -%>
      <%= auto_discovery_link_tag(
        :rss,
        url_for(
          request.params.merge(
            format: "rss",
            page: nil,
            commit: nil,
            only_path: true,
          ),
        ),
        title:
          (
            t(
              "agent.library_group_agent",
              library_group_name: @library_group.display_name.localize,
            ) + " (RSS)"
          ),
      ) %>
      <%= auto_discovery_link_tag(
        :atom,
        url_for(
          request.params.merge(
            format: "atom",
            page: nil,
            commit: nil,
            only_path: true,
          ),
        ),
        title:
          (
            t(
              "agent.library_group_agent",
              library_group_name: @library_group.display_name.localize,
            ) + " (Atom)"
          ),
      ) %>
    <%- end -%>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application",
    "data-turbo-track": "reload",
    type: "module" %>
  </head>
  <body>
    <%= render "page/menu" %>
    <div class="container">
      <div class="row mt-3 mb-3" id="content">
        <%= yield %>
      </div>
      <%= render "page/footer" %>
    </div>
  </body>
</html>
