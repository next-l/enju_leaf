<ul>
  <li><%= t("activerecord.models.resource_import_file") %>:
    <%= link_to @resource_import_file.attachment.filename, @resource_import_file %></li>
  <li><%= t("page.created_at") %>:
    <%= l(@resource_import_file.created_at) %></li>
</ul>
<table class="table table-striped index">
  <tr>
    <th><%= t("activerecord.attributes.resource_import_result.lineno") %></th>
    <th><%= t("activerecord.attributes.resource_import_result.body") %></th>
    <th><%= t("activerecord.models.manifestation") %></th>
    <th><%= t("activerecord.models.item") %></th>
    <th></th>
  </tr>
  <% @resource_import_results.each_with_index do |resource_import_result, idx| %>
    <tr class="line<%= cycle("0", "1") -%>">
      <td><%= @resource_import_results.offset_value + idx + 1 %></td>
      <td><%= resource_import_result.body.inspect.truncate(100) %></td>
      <td><%= if resource_import_result.manifestation
          link_to resource_import_result.manifestation.original_title,
          resource_import_result.manifestation
        end %></td>
      <td><%= if resource_import_result.item
          link_to resource_import_result.item.item_identifier,
          resource_import_result.item
        end %></td>
      <td>
        <%= link_to t("page.show"), resource_import_result %>
        <%= link_to t("page.destroy"),
        resource_import_result,
        data: {
          confirm: t("page.are_you_sure"),
        },
        method: :delete %>
      </td>
    </tr>
  <% end %>
</table>
