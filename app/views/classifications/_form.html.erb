<%= form_with(model: classification) do |f| %>
  <%= error_messages(classification) %>

  <div class="field">
    <%= f.label t("activerecord.models.classification_type") %><br/>
    <%= f.select(
      :classification_type_id,
      @classification_types.collect { |c| [c.name, c.id] },
      {},
      class: "form-select"
    ) %>
  </div>

  <div class="field">
    <%= f.label :category %><br/>
    <%= f.text_field :category, required: true, class: "form-control" %>
  </div>

  <div class="field">
    <%= f.label :label %><br/>
    <%= f.text_field :label, class: "form-control" %>
  </div>

  <div class="field">
    <%= f.label :url %><br/>
    <%= f.url_field :url, class: "form-control resource_url" %>
  </div>

  <div class="field">
    <%= f.label :note %><br/>
    <%= f.text_area :note, class: "form-control" %>
  </div>

  <div class="actions mt-3">
    <%= f.submit class: "btn btn-primary" %>
  </div>
<% end %>
