<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.editing", model: t("activerecord.models.message")) %></h5>
    <div id="content_list" class="card-body">

      <%= form_with(model: @message) do |f| %>
        <%= error_messages(@message) %>

        <div class="field">
          <%= f.label t("message.sender") %><br/>
          <%= @message.sender.username %>
          <%= f.hidden_field :sender_id %>
        </div>

        <div class="field">
          <%= f.label t("message.receiver") %><br/>
          <%= f.text_field :recipient,
                       class: "form-control, resource_title",
                       value: @message.receiver.username %>
        </div>

        <div class="field">
          <%= f.label :subject %><br/>
          <%= f.text_field :subject, class: "form-control resource_title" %>
        </div>

        <div class="field">
          <%= f.label :body %><br/>
          <%= f.text_area :body, class: "form-control" %>
        </div>

        <div class="actions mt-3">
          <%= f.submit class: "btn btn-primary" %>
        </div>
      <% end %>

    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.show"), @message %></li>
      <li><%= link_to t("page.listing", model: t("activerecord.models.message")),
        messages_path %></li>
    </ul>
  </div>
</div>
