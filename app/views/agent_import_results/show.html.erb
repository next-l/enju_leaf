<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.showing", model: t("activerecord.models.agent_import_result")) -%></h5>
    <div id="content_list" class="card-body">
      <p id="notice"><%= notice %></p>

      <p>
        <b><%= t("activerecord.models.agent_import_file") %></b>
        <%= if @agent_import_result.agent_import_file
          @agent_import_result.agent_import_file.attachment.filename
        end %>
      </p>

      <p>
        <b><%= t("activerecord.models.agent") %></b>
        <%= if @agent_import_result.agent
          link_to @agent_import_result.agent.full_name, @agent_import_result.agent
        end %>
      </p>

      <p>
        <b><%= t("activerecord.attributes.agent_import_result.body") %></b>
        <%= @agent_import_result.body %>
      </p>

      <p>
        <b><%= t("page.created_at") %></b>
        <%= l @agent_import_result.created_at %>
      </p>

    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= back_to_index(flash[:page_info]) -%></li>
    </ul>
  </div>
</div>
