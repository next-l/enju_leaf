<div id="content_detail" class="col-md-9">
  <h5 class="title card-header"><%= t("page.showing", model: t("activerecord.models.accept")) -%></h5>
  <div id="content_list" class="card-body">
    <p id="notice"><%= notice %></p>

    <p>
      <strong><%= t("activerecord.models.item") -%>:</strong>
      <% if @accept.item %>
        <%= link_to @accept.item.item_identifier, @accept.item -%>
        (<%= link_to @accept.item.manifestation.original_title, @accept.item.manifestation %>)
      <% end %>
    </p>

    <p>
      <strong><%= t("activerecord.models.user") -%>:</strong>
      <%= if @accept.librarian.try(:profile)
        link_to @accept.librarian.username, @accept.librarian.profile
      end -%>
    </p>

    <p>
      <strong><%= t("page.created_at") -%>:</strong>
      <%= l @accept.created_at %>
    </p>

  </div>
</div>

<div id="submenu" class="col">
  <ul>
    <li><%= link_to t("page.back"), :back -%></li>
  </ul>
</div>
