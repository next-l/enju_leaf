<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.editing", model: t("activerecord.models.event")) -%></h5>
    <div id="content_list" class="card-body">
      <%= render "form", event: @event %>
      <%= render "all_day" %>
    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.show"), @event -%></li>
      <li><%= link_to t("page.back"), events_path(page: flash[:page] ||= nil) -%></li>
    </ul>
  </div>
</div>
