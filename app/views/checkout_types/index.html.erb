<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.listing", model: t("activerecord.models.checkout_type")) -%></h5>
    <div id="content_list" class="card-body">

      <table class="table table-striped index">
        <tr>
          <th id="position"></th>
          <th><%= t("activerecord.attributes.checkout_type.name") -%></th>
          <th>
            <%= t("activerecord.attributes.checkout_type.display_name") -%>
            /
            <%= t("activerecord.attributes.checkout_type.note") -%>
          </th>
          <th></th>
        </tr>

        <%- @checkout_types.each do |checkout_type| -%>
          <tr class="line<%= cycle("0", "1") -%>">
            <td>
              <%- if policy(checkout_type).update? -%>
                <%= move_position(checkout_type) -%>
              <%- end -%>
            </td>
            <td><%= checkout_type.name -%></td>
            <td>
              <%= link_to checkout_type.display_name.localize, checkout_type -%>
              <br/>
              <%= checkout_type.note %>
            </td>
            <td>
              <%- if policy(checkout_type).update? -%>
                <%= link_to t("page.edit"), edit_checkout_type_path(checkout_type) -%>
              <% end %>
              <%- if policy(checkout_type).destroy? -%>
                <%= link_to t("page.destroy"),
                checkout_type_path(checkout_type),
                data: {
                  confirm: t("page.are_you_sure"),
                },
                method: :delete -%>
              <%- end -%>
            </td>
          </tr>
        <%- end -%>
      </table>

    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <%- if policy(CheckoutType).create? -%>
        <li><%= link_to t("page.new", model: t("activerecord.models.checkout_type")),
          new_checkout_type_path -%></li>
      <%- end -%>
    </ul>
  </div>
</div>
