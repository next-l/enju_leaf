<%= render "page/required_field" %>
<%= form_with(model: agent_type) do |f| %>
  <%= error_messages(agent_type) %>

  <div class="field">
    <%= f.label :name %><br/>
    <%= f.text_field :name, required: true, class: "form-control" %>
  </div>
  <div class="field">
    <%= f.label :display_name %><br/>
    <%= f.text_area :display_name, class: "form-control" %>
  </div>
  <div class="field">
    <%= f.label :note %><br/>
    <%= f.text_area :note, class: "form-control" %>
  </div>
  <div class="actions mt-3">
    <%= f.submit class: "btn btn-primary" %>
  </div>
<% end %>
