<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.listing", model: t("activerecord.models.library_group")) -%></h5>
    <div id="content_list" class="card-body">

      <table class="table table-striped index">
        <tr>
          <th><%= t("activerecord.attributes.library_group.display_name") -%></th>
          <th><%= t("activerecord.attributes.library_group.name") -%></th>
          <th><%= t("activerecord.attributes.library_group.email") -%></th>
          <td></td>
        </tr>

        <%- @library_groups.each do |library_group| -%>
          <tr class="line<%= cycle("0", "1") -%>">
            <td><%= link_to h(library_group.display_name.localize), library_group -%></td>
            <td><%= library_group.name -%></td>
            <td><%= library_group.email -%></td>
            <td>
              <%= if policy(library_group).update?
                link_to t("page.edit"), edit_library_group_path(library_group)
              end -%>
            </td>
          </tr>
        <%- end -%>
      </table>

    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("activerecord.models.library"), libraries_path -%></li>
    </ul>
  </div>
</div>
