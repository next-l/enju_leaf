<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.showing", model: t("activerecord.models.checked_item")) -%></h5>
    <div id="content_list" class="card-body">
      <p id="notice"><%= notice %></p>

      <p>
        <strong><%= t("activerecord.models.item") -%>:</strong>
        <%= link_to @checked_item.item_identifier, @checked_item.item -%>
      </p>

      <p>
        <strong><%= t("activerecord.models.basket") -%>:</strong>
        <%= link_to @checked_item.basket.id, @checked_item.basket -%>
      </p>

    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.edit"), edit_checked_item_path(@checked_item) -%></li>
      <li><%= link_to t("page.back"), checked_items_path(basket_id: @checked_item.basket_id) -%></li>
    </ul>
  </div>
</div>
