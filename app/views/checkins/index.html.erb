<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.listing", model: t("activerecord.models.checkin")) -%></h5>
    <div id="content_list" class="card-body">
      <%= render "checkin" %>
      <%= paginate @checkins %>
    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.new", model: t("activerecord.models.checkin")), new_checkin_path -%></li>
      <li><%= link_to t("activerecord.models.checkout"), new_basket_path -%></li>
    </ul>
  </div>
</div>
