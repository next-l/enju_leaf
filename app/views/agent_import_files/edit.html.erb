<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.editing", model: t("activerecord.models.agent_import_file")) -%></h5>
    <div id="content_list" class="card-body">

      <%= form_with(model: @agent_import_file) do |f| -%>
        <%= error_messages(@agent_import_file) -%>

        <div class="field">
          <%= f.label :note -%><br/>
          <%= f.text_area :note -%>
        </div>
        <div class="actions">
          <%= f.submit %>
        </div>
      <%- end -%>

    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.show"), @agent_import_file -%></li>
      <li><%= link_to t("page.back"), agent_import_files_path -%></li>
    </ul>
  </div>
</div>
