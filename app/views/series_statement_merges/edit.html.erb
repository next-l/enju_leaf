<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.editing", model: t("activerecord.models.series_statement_merge")) -%></h5>
    <div id="content_list" class="card-body">

      <%= form_with(model: @series_statement_merge) do |f| -%>
        <%= error_messages(@series_statement_merge) -%>

        <div class="field">
          <%= f.label t("activerecord.models.series_statement") -%><br/>
          <%= f.text_field :series_statement_id -%>
        </div>

        <div class="field">
          <%= f.label t("activerecord.models.series_statement_merge_list") -%><br/>
          <%= f.text_field :series_statement_merge_list_id -%>
        </div>

        <div class="actions">
          <%= f.submit %>
        </div>
      <%- end -%>

    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.show"), @series_statement_merge -%></li>
      <li><%= link_to t("page.back"), series_statement_merges_path -%></li>
    </ul>
  </div>
</div>
