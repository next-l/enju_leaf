<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.editing", model: t("activerecord.models.identifier_type")) -%></h5>
    <div id="content_list" class="card-body">
      <%= render "form", identifier_type: @identifier_type %>
    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.show"), identifier_type_path(@identifier_type) -%></li>
      <li><%= link_to t("page.back"), identifier_types_path -%></li>
    </ul>
  </div>
</div>
