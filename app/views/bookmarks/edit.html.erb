<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.editing", model: t("activerecord.models.bookmark")) %></h5>
    <div id="content_list" class="card-body">

      <%= form_for(@bookmark, url: bookmark_path(@bookmark)) do |f| %>
        <%= error_messages(@bookmark) %>

        <div class="field">
          <%= f.label t("page.title") %><br/>
          <% if @bookmark.manifestation %>
            <%= link_to @bookmark.manifestation.original_title,
            @bookmark.manifestation.access_address %>
          <% else %>
            <%= f.text_field :manifestation_id, class: "form-control" %>
          <% end %>
        </div>

        <div class="field">
          <%= f.label t("activerecord.models.tag") %><br/>
          <%= f.text_field :tag_list, class: "form-control resource_title" %>
        </div>

        <div class="field">
          <%= f.label :shared %>
          <%= f.check_box :shared %>
        </div>

        <div class="field">
          <%= f.label :note %><br/>
          <%= f.text_area :note, class: "form-control resource_textarea" %>
        </div>

        <div class="actions mt-3">
          <%= f.submit class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.showing", model: t("activerecord.models.manifestation")),
        @bookmark.manifestation %></li>
      <li><%= link_to t("page.show"), @bookmark %></li>
      <li><%= link_to t("page.back"), bookmarks_path(user_id: @bookmark.user.username) %></li>
    </ul>
  </div>
</div>
