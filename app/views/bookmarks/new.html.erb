<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.new", model: t("activerecord.models.bookmark")) %></h5>
    <div id="content_list" class="card-body">

      <%= form_for(@bookmark) do |f| %>
        <%= error_messages(@bookmark) %>

        <div class="field">
          <%= f.label t("page.title") %><br/>
          <%= f.text_field :title, class: "form-control resource_title" %>
        </div>

        <div class="field">
          <%= f.label :url %><br/>
          <% if @bookmark.url %>
            <%= link_to @bookmark.url, @bookmark.url %>
            <%= f.hidden_field :url, class: "form-control resource_url" %>
          <% else %>
            <%= f.url_field :url, class: "form-control resource_url" %>
          <% end %>
        </div>

        <div class="field">
          <%= f.label t("page.tag") %><br/>
          <%= f.text_field :tag_list, class: "form-control" %>
        </div>

        <div class="field">
          <%= f.label :shared %>
          <%= f.check_box :shared %>
        </div>

        <div class="field">
          <%= f.label :note %><br/>
          <%= f.text_area :note, class: "form-control resource_textarea" %>
        </div>

        <div class="actions mt-3">
          <%= f.submit class: "btn btn-primary" %>
        </div>
        <script>
        document.addEventListener('DOMContentLoaded', function() {
          document.getElementById('bookmark_tag_list').focus();
        });
        </script>
      <% end %>
    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.back"), :back %></li>
    </ul>
  </div>
</div>
