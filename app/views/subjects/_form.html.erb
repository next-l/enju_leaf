<%= form_with(model: subject) do |f| %>
  <%= error_messages(subject) %>

  <div class="field">
    <%= f.label t("activerecord.models.subject_heading_type") %>
    <%= f.select(
      :subject_heading_type_id,
      @subject_heading_types.collect { |s| [s.display_name.localize, s.id] },
      {},
      class: "form-select"
    ) %>
  </div>
  <div class="field">
    <%= f.label t("activerecord.models.subject_type") %>
    <%= f.select(
      :subject_type_id,
      @subject_types.collect { |s| [s.display_name.localize, s.id] },
      {},
      class: "form-select"
    ) %>
  </div>

  <div class="field">
    <%= f.label :term %><br/>
    <%= f.text_field :term, required: true, class: "form-control" %>
  </div>
  <div class="field">
    <%= f.label :term_transcription %><br/>
    <%= f.text_field :term_transcription, class: "form-control" %>
  </div>
  <div class="field">
    <%= f.label :note %><br/>
    <%= f.text_area :note, class: "form-control" %>
  </div>
  <div class="actions mt-3">
    <%= f.submit class: "btn btn-primary" %>
  </div>
<% end %>
