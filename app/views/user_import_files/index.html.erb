<div id="content_detail" class="col-md-9">
  <h5 class="title card-header"><%= t("page.listing", model: t("activerecord.models.user_import_file")) -%></h5>
  <div id="content_list" class="card-body">

    <table class="table table-striped index">
      <thead>
        <tr>
          <th style="width: 30px">Id</th>
          <th><%= t("activerecord.attributes.user_import_file.user_import_file_name") -%></th>
          <th><%= t("activerecord.attributes.user_import_file.edit_mode") -%></th>
          <th><%= t("activerecord.attributes.user_import_file.executed_at") -%></th>
          <th><%= t("activerecord.attributes.user_import_file.state") -%></th>
          <th></th>
        </tr>
      </thead>

      <tbody>
        <% @user_import_files.each do |user_import_file| %>
          <tr class="line<%= cycle("0", "1") -%>">
            <td><%= link_to (user_import_file.id), user_import_file -%></td>
            <td>
              <%= if user_import_file.attachment.attached?
                link_to user_import_file.attachment.filename,
                rails_blob_path(user_import_file.attachment)
              end %>
              <br/>
              <%= t("activerecord.models.user") -%>:
              <%= if user_import_file.user.try(:profile)
                link_to user_import_file.user.username, user_import_file.user.profile
              end -%></td>
            <td><%= user_import_file.edit_mode -%></td>
            <td><%= l(user_import_file.executed_at) if user_import_file.executed_at -%></td>
            <td><%= localized_state(user_import_file.current_state) -%></td>
            <td>
              <%= link_to t("page.show"), user_import_file -%>
              <%= link_to t("page.destroy"),
              user_import_file,
              data: {
                confirm: t("page.are_you_sure"),
              },
              method: :delete -%>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <%= paginate(@user_import_files) -%>
  </div>
</div>

<div id="submenu" class="col">
  <ul>
    <li><%= link_to t("page.new", model: t("activerecord.models.user_import_file")),
      new_user_import_file_path -%></li>
  </ul>
</div>
