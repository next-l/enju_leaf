<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.new", model: t("activerecord.models.subscribe")) %></h5>
    <div id="content_list" class="card-body">

      <%= form_with(model: @subscribe) do |f| %>
        <%= error_messages(@subscribe) %>
        <div class="field">
          <%= f.label t("activerecord.models.subscription") %><br/>
          <% if @subscription %>
            <%= link_to @subscription.title, @subscription %>
            <%= f.hidden_field :subscription_id, value: @subscription.id %>
          <% else %>
            <%= f.text_field :subscription_id, value: params[:subscription_id], class: "form-control" %>
          <% end %>
        </div>

        <div class="field">
          <%= f.label t("activerecord.models.work") %><br/>
          <% if @work %>
            <%= link_to @work.original_title, @work %>
            <%= f.hidden_field :work_id, value: @work.id %>
          <% else %>
            <%= f.text_field :work_id, value: params[:work_id], class: "form-control" %>
          <% end %>
        </div>
        <div class="field">
          <%= f.label :start_at %><br/>
          <%= f.text_field :start_at, class: "form-control date_field" %>
        </div>
        <div class="field">
          <%= f.label :end_at %><br/>
          <%= f.text_field :end_at, class: "form-control date_field" %>
        </div>

        <div class="actions mt-3">
          <%= f.submit class: "btn btn-primary" %>
        </div>
      <% end %>

    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= if @subscription
          link_to t("activerecord.models.subscription"),
          subscription_path(@subscription)
        end %></li>
      <li><%= if @subscription
          link_to t("page.listing", model: t("activerecord.models.work")),
          subscription_works_path(@subscription)
        end %></li>
    </ul>
  </div>
</div>
