<h5 class="title card-header"><%= t("page.new", model: t("activerecord.models.item_has_use_restriction")) -%></h5>

<%= form_for(@item_has_use_restriction) do |f| -%>
  <%= error_messages(@item_has_use_restriction) -%>
  <div class="field">
    <%= f.label t("activerecord.models.item") -%><br/>
    <%- if @item -%>
      <%= link_to @item.item_identifier, @item -%>
      (<%= link_to @item.manifestation.original_title, @item.manifestation -%>)
      <%= f.hidden_field :item_id, value: @item.id -%>
    <%- else -%>
      <%= f.text_field :item_id -%>
    <%- end -%>
  </div>

  <div class="field">
    <%= f.label t("activerecord.models.use_restriction") -%><br/>
    <%= f.select(:use_restriction_id, @use_restrictions.collect { |u| [u.name, u.id] }) -%>
  </div>

  <div class="actions">
    <%= f.submit %>
  </div>
<%- end -%>

<div id="submenu" class="col">
  <%= link_to t("page.back"), item_has_use_restrictions_path -%>
</div>
