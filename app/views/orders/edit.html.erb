<div id="content_detail" class="col-md-9">
  <h5 class="title card-header"><%= t("page.editing", model: t("activerecord.models.order")) -%></h5>
  <div id="content_list" class="card-body">

    <%= form_for(@order) do |f| -%>
      <%= error_messages(@order) -%>
      <div class="field">
        <%= f.label t("activerecord.models.order_list") -%><br/>
        <%= f.text_field :order_list_id -%>
      </div>

      <div class="field">
        <%= f.label t("activerecord.models.purchase_request") -%><br/>
        <%= f.text_field :purchase_request_id -%>
      </div>

      <div class="actions">
        <%= f.submit %>
      </div>
    <%- end -%>

  </div>
</div>

<div id="submenu" class="col">
  <ul>
    <li><%= link_to t("page.show"), order_path(@order) -%></li>
    <li><%= link_to t("page.back"), orders_path -%></li>
  </ul>
</div>
