<div id="content_detail" class="col-md-9">
  <div class="card">
    <h5 class="title card-header"><%= t("page.showing", model: t("activerecord.models.order")) -%></h5>
    <div id="content_list" class="card-body">
      <p id="notice"><%= notice %></p>

      <p>
        <strong><%= t("activerecord.models.order_list") -%>:</strong>
        <%= link_to @order.order_list.title,
        purchase_requests_path(order_list_id: @order.order_list_id) -%>
      </p>

      <p>
        <strong><%= t("activerecord.models.purchase_request") -%>:</strong>
        <%= link_to @order.purchase_request.title,
        purchase_request_path(@order.purchase_request) -%>
      </p>

    </div>
  </div>
</div>

<div id="submenu" class="col">
  <div class="card">
    <ul>
      <li><%= link_to t("page.back_to", model: t("activerecord.models.purchase_request")),
        purchase_requests_path(order_list_id: @order.order_list_id) -%></li>
    </ul>
  </div>
</div>
