<%= form_with(model: user_group_has_checkout_type) do |f| %>
  <%= error_messages(user_group_has_checkout_type) %>

  <div class="field">
    <%= f.label t("activerecord.models.user_group") %><br/>
    <%= f.select(
      :user_group_id,
      @user_groups.collect { |u| [u.display_name.localize, u.id] },
      {},
      class: "form-select"
    ) %>
  </div>
  <div class="field">
    <%= f.label t("activerecord.models.checkout_type") %><br/>
    <%= f.select(
      :checkout_type_id,
      @checkout_types.collect { |c| [c.display_name.localize, c.id] },
      {},
      class: "form-select"
    ) %>
  </div>
  <div class="field">
    <%= f.label :checkout_limit %><br/>
    <%= f.number_field :checkout_limit, class: "form-control resource_integer" %>
  </div>

  <div class="field">
    <%= f.label :checkout_period %><br/>
    <%= f.number_field :checkout_period, class: "form-control resource_integer" %>
  </div>

  <div class="field">
    <%= f.label :checkout_renewal_limit %><br/>
    <%= f.number_field :checkout_renewal_limit, class: "form-control resource_integer" %>
  </div>

  <div class="field">
    <%= f.label :reservation_limit %><br/>
    <%= f.number_field :reservation_limit, class: "form-control resource_integer" %>
  </div>

  <div class="field">
    <%= f.label :set_due_date_before_closing_day %>
    <%= f.check_box :set_due_date_before_closing_day, class: "form-check-input" %>
  </div>

  <div class="field">
    <%= f.label :note %><br/>
    <%= f.text_area :note, class: "form-control" %>
  </div>
  <div class="actions mt-3">
    <%= f.submit class: "btn btn-primary" %>
  </div>
<% end %>
